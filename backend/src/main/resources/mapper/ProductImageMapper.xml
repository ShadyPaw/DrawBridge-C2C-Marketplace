<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cargoco.mapper.ProductImageMapper">

    <resultMap id="BaseResultMap" type="com.cargoco.entity.ProductImage">
        <id column="id" property="id"/>
        <result column="product_id" property="productId"/>
        <result column="image_url" property="imageUrl"/>
        <result column="is_cover" property="isCover"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findByProductId" resultMap="BaseResultMap">
        SELECT * FROM product_image WHERE product_id = #{productId} ORDER BY sort_order ASC
    </select>

    <select id="findCoverByProductId" resultMap="BaseResultMap">
        SELECT * FROM product_image WHERE product_id = #{productId} AND is_cover = 1 LIMIT 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product_image (product_id, image_url, is_cover, sort_order)
        VALUES (#{productId}, #{imageUrl}, #{isCover}, #{sortOrder})
    </insert>

    <insert id="batchInsert">
        INSERT INTO product_image (product_id, image_url, is_cover, sort_order) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.productId}, #{item.imageUrl}, #{item.isCover}, #{item.sortOrder})
        </foreach>
    </insert>

    <delete id="deleteByProductId">
        DELETE FROM product_image WHERE product_id = #{productId}
    </delete>
</mapper>
