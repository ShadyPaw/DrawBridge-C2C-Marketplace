<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cargoco.mapper.CreditRecordMapper">

    <resultMap id="BaseResultMap" type="com.cargoco.entity.CreditRecord">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="change_type" property="changeType"/>
        <result column="change_value" property="changeValue"/>
        <result column="before_score" property="beforeScore"/>
        <result column="after_score" property="afterScore"/>
        <result column="related_id" property="relatedId"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO credit_record (user_id, change_type, change_value, before_score, after_score, related_id, remark)
        VALUES (#{userId}, #{changeType}, #{changeValue}, #{beforeScore}, #{afterScore}, #{relatedId}, #{remark})
    </insert>

    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT * FROM credit_record WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>
</mapper>
